# Local dev isolation — copy this file to .env.development.local (gitignored).
#
# `next dev` loads .env.development.local with HIGHER precedence than
# .env.local, so these blanks override any production credentials that live in
# .env.local. Blank values make databaseConfigured()/snowflakeConfigured()/
# eshipzConfigured() all false: the app runs on the in-memory seed repo and no
# integration can reach production. instrumentation-node.ts additionally
# refuses to boot a non-production process whose DATABASE_URL points at the
# production host — so if you skip this file, dev fails loudly instead of
# silently touching prod.

DATABASE_URL=
SNOWFLAKE_ACCOUNT=
SNOWFLAKE_USERNAME=
SNOWFLAKE_PRIVATE_KEY=
SNOWFLAKE_PRIVATE_KEY_PASSPHRASE=
SNOWFLAKE_ROLE=
SNOWFLAKE_WAREHOUSE=
SNOWFLAKE_DATABASE=
SNOWFLAKE_SCHEMA=
ESHIPZ_API_TOKEN=
UC_BASE_URL=
UC_CLIENT_ID=
UC_USERNAME=
UC_PASSWORD=

NEXTAUTH_URL=http://localhost:3000
RETAILJOURNEY_DEV_PERSONA=1
