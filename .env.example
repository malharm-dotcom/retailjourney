# RetailJourney — environment
# Copy to .env.local for development. All values are read lazily at runtime.

# Session signing (required in production; NEXTAUTH_SECRET preferred)
NEXTAUTH_SECRET=change-me
NEXTAUTH_URL=http://localhost:3000

# PostgreSQL (M2). On Coolify use the INTERNAL hostname (same Docker network);
# for local dev point at the exposed dev port. When unset the app falls back
# to in-memory seed data (state resets on restart).
DATABASE_URL=postgresql://user:password@host:5432/retailjourney

# Seed guard — prisma db seed WIPES Order/OrderEvent/RulebookEntry and refuses
# to run unless this is set (the dev DB may be the shared Coolify one).
# SEED_CONFIRM=1

# Google SSO (optional until M5 — the login page hides the button when unset)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# Enable the persona switcher (required until Google SSO is configured; any environment)
RETAILJOURNEY_DEV_PERSONA=1

# Unicommerce (M2 sync) — token fetched via OAuth password grant, cached, never logged
UC_BASE_URL=https://4mclothingllp.unicommerce.com
UC_CLIENT_ID=my-trusted-client
UC_USERNAME=
UC_PASSWORD=
# Export job type for the B2B discovery sweep (default shown)
# UC_EXPORT_JOB_TYPE=4mclothingllp Sale Orders

# eShipz (M2 sync) — Tracking API v2
ESHIPZ_API_TOKEN=
# ESHIPZ_BASE_URL=https://app.eshipz.com
# Shared secret for the real-time webhook (X-Webhook-Secret header on
# POST /api/webhooks/eshipz) — set the same value in the eShipz dashboard
ESHIPZ_WEBHOOK_SECRET=

# Sync scheduler interval in minutes (default 15; <=0 disables)
# SYNC_INTERVAL_MINUTES=15

TZ=Asia/Kolkata
